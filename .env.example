# ============================================
# GENERAL
# ============================================
TIMEZONE=Asia/Jakarta
DOMAIN=yourdomain.com

# ============================================
# n8n
# ============================================
N8N_USER=admin
N8N_PASSWORD=your_secure_password_here
N8N_HOST=n8n.yourdomain.com

# ============================================
# LLM Configuration - OpenAI-Compatible Provider
# ============================================
# This project supports any OpenAI-compatible API provider
# Choose based on your needs: cost, privacy, performance

# Primary LLM Provider Configuration
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4

# Provider Examples:
# 
# OpenAI (Official):
# LLM_API_KEY=sk-...
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4
#
# OpenRouter (100+ models):
# LLM_API_KEY=sk-or-v1-...
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_MODEL=anthropic/claude-3.5-sonnet
#
# Groq (Ultra-fast):
# LLM_API_KEY=gsk_...
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_MODEL=llama-3.1-70b-versatile
#
# Together AI (Open models):
# LLM_API_KEY=...
# LLM_BASE_URL=https://api.together.xyz/v1
# LLM_MODEL=meta-llama/Llama-3-70b-chat-hf
#
# Ollama (Local/Self-hosted):
# LLM_API_KEY=ollama
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=llama3.1:8b

# Legacy/Compatibility (for tools that expect these variable names)
LLM_PROVIDER=openai
OPENAI_API_KEY=${LLM_API_KEY}
OPENAI_API_BASE=${LLM_BASE_URL}

# ============================================
# OpenFang (DEPRECATED - replaced by LangGraph agent)
# ============================================
OPENFANG_SECRET=your_openfang_secret

# ============================================
# LangGraph Agent (AI Agent Engine)
# ============================================
# Shared secret for bot <-> agent HTTP auth. Generate with: openssl rand -hex 32
AGENT_SECRET=your_agent_secret_here

# ============================================
# Qdrant - Vector Database (External Provider)
# ============================================
# Use Qdrant Cloud (managed vector database)
# Sign up: https://cloud.qdrant.io
# Create cluster → Get Cluster URL and API Key
QDRANT_URL=https://your-cluster-id.qdrant.io:6333
QDRANT_API_KEY=your_qdrant_cloud_api_key

# Provider tiers:
# - Free: 1GB storage, 1M vectors (sufficient for personal use)
# - Starter: $25/month (5GB storage, 5M vectors)
# - Standard: $95/month (20GB storage, 20M vectors)

# ============================================
# Cal.com
# ============================================
CALCOM_HOST=cal.yourdomain.com
AGENT_HOST=agent.yourdomain.com
CALCOM_SECRET=your_calcom_secret
CALCOM_ENCRYPTION_KEY=your_encryption_key

# Cal.com API Key (for API calls)
# Get from: Cal.com Dashboard → Settings → API Keys → Create New API Key
CALCOM_API_KEY=cal_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Note: 
# - CALCOM_SECRET: Used for webhook authentication
# - CALCOM_API_KEY: Used for API calls (get bookings, create events, etc.)

# ============================================
# Database - External PostgreSQL Provider
# ============================================
# Use external PostgreSQL provider (Supabase, Neon, Railway, etc.)
# Format: postgresql://username:password@host:port/database?sslmode=require
DATABASE_URL=postgresql://user:password@db.provider.com:5432/calcom?sslmode=require

# Example providers:
# - Supabase: postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
# - Neon: postgresql://[USER]:[PASSWORD]@[HOST]/[DATABASE]?sslmode=require
# - Railway: postgresql://postgres:[PASSWORD]@[HOST]:[PORT]/railway
# - Render: postgresql://[USER]:[PASSWORD]@[HOST]/[DATABASE]

# ============================================
# Cloudflare R2 (S3-Compatible Object Storage)
# ============================================
# Get credentials from: https://dash.cloudflare.com → R2 → Manage R2 API Tokens
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET=secretary-files
R2_ENDPOINT=https://${R2_ACCOUNT_ID}.r2.cloudflarestorage.com
R2_PUBLIC_URL=https://files.yourdomain.com  # Optional: custom domain

# Free tier: 10GB storage, unlimited egress
# Pricing after free tier: $0.015/GB/month storage

# ============================================
# Telegram
# ============================================
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_ALLOWED_USERS=your_telegram_user_id

# ============================================
# External Services (Optional)
# ============================================
# SMTP for email notifications
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=your_sendgrid_api_key
SMTP_FROM=secretary@yourdomain.com

# ============================================
# Multi-repo Q&A (Phase 1) + Auto PR Review
# ============================================
# Personal Access Tokens:
# - GH_PAT       : GitHub fine-grained PAT, "Contents: read" or classic "repo" for private.
#                   For PR review: also needs "Pull requests: write" (to post reviews).
# - GITLAB_PAT   : GitLab PAT with "read_repository" scope for Q&A.
#                   For MR review: needs "api" scope (to post notes on merge requests).
# Tokens are injected at clone/fetch time only and never persisted in .git/config.
#
# Webhook secrets (for Auto PR Review):
# - GH_WEBHOOK_SECRET  : Secret configured in GitHub repo webhook settings (HMAC SHA-256)
# - GITLAB_WEBHOOK_SECRET : Secret token configured in GitLab webhook settings
GH_PAT=
GH_WEBHOOK_SECRET=
GITLAB_PAT=
GITLAB_WEBHOOK_SECRET=

# Where cloned repos live inside the langgraph-agent container.
# Mapped from host volume `repos_data`. Do not put on a shared/public path.
REPO_BASE_DIR=/repos

# Path inside the container to the repo registry YAML (committed file in this repo).
REPOS_CONFIG_PATH=/app/repos.yml

# ============================================
# Resource alert thresholds (Phase 1)
# ============================================
# Sustained host RAM/disk percent that triggers Telegram warning/critical alerts.
# All alerts are transition-only: state file dedupes spam, recovery message fires
# on warning/critical -> ok edge.
RESOURCE_DISK_WARN_PCT=80
RESOURCE_DISK_CRIT_PCT=90
RESOURCE_MEM_WARN_PCT=85
RESOURCE_MEM_CRIT_PCT=92
# Minutes RAM must stay above warn threshold before an alert fires.
# Filters out short embedding/indexing spikes.
RESOURCE_MEM_SUSTAINED_MINUTES=30
# Swap usage thresholds (high swap usually means RAM pressure -> upgrade signal).
RESOURCE_SWAP_WARN_PCT=50
RESOURCE_SWAP_CRIT_PCT=70
# Qdrant total point count thresholds (free tier limit = 1,000,000).
RESOURCE_QDRANT_WARN_POINTS=800000
RESOURCE_QDRANT_CRIT_POINTS=950000
# PostgreSQL probe timeout (seconds). Probe runs SELECT 1 over DATABASE_URL.
RESOURCE_POSTGRES_CONNECT_TIMEOUT_SEC=5
# PostgreSQL database size thresholds (MB). Set to 0 to disable storage check.
# Default 400/480 MB suits Supabase/Neon free tier (500MB limit).
RESOURCE_POSTGRES_STORAGE_WARN_MB=400
RESOURCE_POSTGRES_STORAGE_CRIT_MB=480
# Per-container memory usage vs its Docker memory limit.
# Alerts before OOM kill happens.
RESOURCE_CONTAINER_MEM_WARN_PCT=85
RESOURCE_CONTAINER_MEM_CRIT_PCT=95

# ============================================
# Voice Transcription (Whisper API)
# ============================================
# Defaults to LLM_BASE_URL/LLM_API_KEY if not set separately.
# Override if using a dedicated Whisper endpoint (e.g. Groq whisper-large-v3).
# WHISPER_API_BASE=https://api.groq.com/openai
# WHISPER_API_KEY=gsk_...
WHISPER_MODEL=whisper-1
MAX_VOICE_DURATION_SEC=300

# ============================================
# Monitoring (Prometheus + Alertmanager)
# ============================================
# Prometheus scrapes node_exporter on each VPS.
# Alertmanager sends alerts to Telegram using the same bot token.
# Add VPS targets in prometheus/prometheus.yml.
# /monitor <name> can also list containers via SSH docker ps.
MONITOR_SSH_TARGETS={"erpstg":{"host":"119.2.52.24","port":"3270","user":"ubuntu"}}

# ============================================
# Docker Image Hygiene (daily 02:15 WIB)
# ============================================
# Audits docker system df locally + per VPS via SSH.
# Auto-prunes dangling images when reclaimable size exceeds threshold.
DOCKER_HYGIENE_ENABLED=true
DOCKER_HYGIENE_HOUR=2
DOCKER_HYGIENE_MINUTE=15
DOCKER_HYGIENE_RECLAIMABLE_WARN_GB=5
DOCKER_HYGIENE_AUTO_PRUNE=true

# ============================================
# DNS Health Monitor (every 4h)
# ============================================
# Multi-resolver dig (Cloudflare/Google/Quad9) to detect divergence/hijack.
# Domains seeded from SSL_CHECK_DOMAINS unless overridden via /dns add ...
DNS_CHECK_ENABLED=true
DNS_CHECK_INTERVAL_SEC=14400

# ============================================
# Firewall Audit Agent (daily 03:30 WIB)
# ============================================
# SSH ke setiap VPS, list public-listening TCP ports via ss/netstat,
# flag yang tidak masuk whitelist (default: 22/80/443).
# Whitelist managed via /firewall add <vps> <port>.
FIREWALL_AUDIT_ENABLED=true
FIREWALL_AUDIT_HOUR=3
FIREWALL_AUDIT_MINUTE=30
